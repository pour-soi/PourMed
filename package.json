{
  "name": "pourmed",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && wrangler deploy --dry-run --outdir dist-worker",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "icons": "node scripts/generate-icons.mjs",
    "secrets:generate": "node scripts/generate-secrets.mjs",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "verify:v2-api": "node scripts/verify-v2-api.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm verify:assets && pnpm secret:scan && pnpm audit --prod",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "1.0.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.12.16",
    "@cloudflare/workers-types": "5.20260721.1",
    "@eslint/js": "9.31.0",
    "@types/node": "24.0.15",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.31.0",
    "globals": "16.3.0",
    "prettier": "3.6.2",
    "sharp": "0.34.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "7.0.6",
    "vitest": "3.2.4",
    "wrangler": "4.113.0"
  },
  "engines": {
    "node": ">=22"
  }
}
